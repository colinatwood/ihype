{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run guard:design 2>/dev/null || true",
            "statusMessage": "Checking design guards..."
          }
        ]
      }
    ]
  }
}
