{
  "name": "ihype",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run guard:design && node scripts/bump-sw-version.mjs",
    "build": "next build --webpack",
    "guard:design": "node scripts/guard-claude-design.mjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:launch": "tsx prisma/launch-seed.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "smoke:production": "node scripts/smoke-production.mjs",
    "admin:reset-test-logins": "node scripts/reset-test-logins.mjs",
    "analyze": "ANALYZE=true npm run build",
    "cf:build": "node scripts/bump-sw-version.mjs && opennextjs-cloudflare build && node scripts/patch-worker-bundle.mjs",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy worker.js --experimental-autoconfig=false"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@auth/prisma-adapter": "2.11.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.62.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.8",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.0",
    "uqr": "^0.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@playwright/test": "^1.49.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.93.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next-auth": "5.0.0-beta.31",
    "@auth/prisma-adapter": "2.11.2"
  }
}
