{
    "$schema":  "https://openapi.vercel.sh/vercel.json",
    "framework":  "nextjs",
    "buildCommand":  "npm run vercel-build",
    "functions":  {
                      "src/app/api/**/route.{ts,js}":  {
                                                           "maxDuration":  30
                                                       },
                      "src/app/api/cron/**/route.{ts,js}":  {
                                                                "maxDuration":  60
                                                            }
                  },
    "crons":  [
                  {
                      "path":  "/api/cron/show-lifecycle",
                      "schedule":  "* * * * *"
                  },
                  {
                      "path":  "/api/cron/expire-reservations",
                      "schedule":  "*/5 * * * *"
                  },
                  {
                      "path":  "/api/cron?job=digest",
                      "schedule":  "0 10 * * 1"
                  },
                  {
                      "path":  "/api/cron?job=health-check",
                      "schedule":  "*/15 * * * *"
                  },
                  {
                      "path":  "/api/cron?job=artist-digest",
                      "schedule":  "0 10 * * 2"
                  },
                  {
                      "path":  "/api/cron?job=onboarding",
                      "schedule":  "0 9 * * *"
                  },
                  {
                      "path":  "/api/cron?job=show-reminders",
                      "schedule":  "0 */6 * * *"
                  },
                  {
                      "path":  "/api/cron?job=db-health",
                      "schedule":  "0 8 * * 1"
                  },
                  {
                      "path":  "/api/cron?job=weekly-picks",
                      "schedule":  "0 9 * * 5"
                  },
                  {
                      "path":  "/api/cron?job=admin-report",
                      "schedule":  "0 8 * * 1"
                  }
              ]
}
