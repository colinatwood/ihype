DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="https://ihype.org"
NEXT_PUBLIC_APP_URL="https://ihype.org"

# SMTP powers sign-in MFA, password reset, and ticket emails.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-username"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="iHYPE <no-reply@ihype.org>"

# Optional platform integrations.
OPENAI_API_KEY=""
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
