DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Use a direct/non-pooled Postgres URL for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="https://ihype.org"
NEXT_PUBLIC_APP_URL="https://ihype.org"

# Email powers sign-in MFA, password reset, and ticket emails.
# Resend is preferred when RESEND_API_KEY is set; SMTP remains the fallback.
RESEND_API_KEY=""
EMAIL_FROM="iHYPE <no-reply@ihype.org>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-username"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="iHYPE <no-reply@ihype.org>"

# Optional platform integrations.
OPENAI_API_KEY=""
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
BLOB_READ_WRITE_TOKEN=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# REQUIRED for closed beta: comma-separated list of valid invite codes.
BETA_INVITE_CODES="IHYPE,HYPE2026,BETA,LISTEN"

# Web Push (VAPID) — required for push notifications.
# Generate with: node scripts/generate-vapid-keys.mjs
# Then set as Cloudflare Worker secrets: wrangler secret put VAPID_PUBLIC_KEY
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@ihype.org"

# Production safety switches.
# Temporarily set both values only during first admin bootstrap, then remove/disable them.
ALLOW_ADMIN_SETUP="false"
ADMIN_SETUP_SECRET=""
ADMIN_DEVICE_SECRET=""
# REQUIRED for closed beta: keep true until public launch.
FEATURE_REQUIRE_INVITE_CODE="true"
# Keep database media uploads off in production unless a temporary admin-only exception is needed.
FEATURE_ALLOW_DATABASE_MEDIA_STORAGE="false"
# Live streaming is disabled by default; promoter shows are prerecorded radio-style shows.
FEATURE_ENABLE_LIVE_STREAMS="false"

# Sentry error monitoring (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
