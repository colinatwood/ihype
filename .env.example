# App
NODE_ENV=production
AUTH_URL=https://ihype.org
NEXT_PUBLIC_APP_URL=https://ihype.org
AUTH_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_APP_NAME=ihype.org
NEXT_PUBLIC_SUPPORT_EMAIL=support@ihype.org

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Password reset email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=login@ihype.org

# Mux
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_secret

# Optional operational settings
# SENTRY_DSN=
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=60000
# FEATURE_ENABLE_SIGNUPS=true
# FEATURE_ENABLE_DEMO_LOGINS=false
# FEATURE_ENABLE_STREAMING=true
# FEATURE_ENABLE_HYPE=true
# ALLOW_PRODUCTION_SEEDING=false
